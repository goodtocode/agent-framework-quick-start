@using Goodtocode.AgentFramework.Presentation.Web.Library.Analytics

@inject IConfiguration Configuration

<!DOCTYPE html>
<html lang="en-US">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />

    <meta name="description" content="GoodToCode Quick-start for Microsoft Agent Framework: build, test, and run AI-assisted chat workflows with a production-ready .NET template." />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />

    <meta property="og:site_name" content="GoodToCode" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="GoodToCode Quick-start for Microsoft Agent Framework" />
    <meta property="og:description" content="Official GoodToCode .NET template for AI-assisted chat workflows." />
    <meta property="og:image" content="/img/logo.png" />
    <meta property="og:url" content="/" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="GoodToCode Quick-start for Microsoft Agent Framework" />
    <meta name="twitter:description" content="Official GoodToCode .NET template for AI-assisted chat workflows." />
    <meta name="twitter:image" content="/img/logo.png" />

    <link rel="alternate" type="application/json" title="AI Compatibility Manifest" href="/ai-manifest.json" />

    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Goodtocode.AgentFramework.Presentation.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
    <ClarityAnalytics ProjectId="@Configuration["Clarity:ProjectId"]" />
    <script src="_content/Microsoft.FluentUI.AspNetCore.Components/js/loading-theme.js" type="text/javascript"></script>
</head>

<body>
    <loading-theme storage-name="theme"></loading-theme>
    <FluentDesignTheme StorageName="theme" />
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
</body>

</html>

