@inject NavigationManager Navigation
@inject Microsoft.Extensions.Options.IOptions<Goodtocode.AgentFramework.Presentation.Web.Infrastructure.Options.EntraExternalIdWebOptions> EntraExternalIdOptions

<FluentLabel Typo="Typography.H3">Redirecting to password reset...</FluentLabel>

@code {
    protected override void OnInitialized()
    {
        var passwordResetUrl = EntraExternalIdOptions.Value.PasswordResetUrl;
        if (string.IsNullOrWhiteSpace(passwordResetUrl))
        {
            Navigation.NavigateTo("/", forceLoad: false);
            return;
        }

        Navigation.NavigateTo(passwordResetUrl, forceLoad: true);
    }
}
