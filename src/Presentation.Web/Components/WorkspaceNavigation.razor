@using Goodtocode.AgentFramework.Presentation.Web.Components.Models
<FluentStack Orientation="Orientation.Vertical" VerticalGap="8" HorizontalAlignment="@(ResolvedCenter ? HorizontalAlignment.Center : HorizontalAlignment.Left)">
    <HorizontalMenu Items="ResolvedItems" Center="@ResolvedCenter" UseSelectedState="true" NonSelectedAppearance="Appearance.Accent" SelectedAppearance="Appearance.Accent" />
</FluentStack>

@code {
    [Parameter] public PlatformNavigationModel? Model { get; set; }
    [Parameter] public IReadOnlyList<HorizontalMenuItem>? Items { get; set; }
    [Parameter] public bool? Center { get; set; }

    private IReadOnlyList<HorizontalMenuItem> ResolvedItems => Model?.Items ?? Items ?? [];
    private bool ResolvedCenter => Model?.Center ?? Center ?? false;
}
